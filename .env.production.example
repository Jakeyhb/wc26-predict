ENVIRONMENT=production
POSTGRES_URL=postgresql+asyncpg://worldcup:CHANGE_ME@postgres:5432/worldcup
REDIS_URL=redis://redis:6379/0

# ============================================================
# Data source API keys — sign up at each provider's website
# ============================================================

# football-data.org: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_CALLS_PER_MINUTE=9
# Event Registry: https://eventregistry.org/
EVENT_REGISTRY_API_KEY=
# GDELT: https://www.gdeltproject.org/
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc

# The Odds API: https://the-odds-api.com/
ODDS_API_KEY=

# Market odds providers — two different services, use the one you have
# API-Sports / api-football.com: https://v3.football.api-sports.io  (auth=x-apisports-key header)
API_FOOTBALL_KEY=
# apifootball.com: https://apiv3.apifootball.com/  (auth=APIkey query param)
APIFOOTBALL_COM_KEY=

# ============================================================
# LLM configuration — DeepSeek (OpenAI-compatible API)
# IMPORTANT: Do NOT include /v1 in the URL.
# The OpenAI SDK auto-appends /v1, so /v1 here causes double /v1/v1.
# ============================================================
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-pro
LLM_TIMEOUT_SECONDS=30

ADMIN_TOKEN=CHANGE_ME_TO_RANDOM_32_CHARS
CORS_ORIGINS=https://your-domain.com
SENTRY_DSN=
MODEL_ARTIFACT_DIR=/app/artifacts
PREDICTION_MODEL_VERSION=1.0.0
EMBEDDING_MODE=local

APP_BASE_URL=https://your-domain.com
VITE_API_BASE_URL=https://your-domain.com
VITE_USE_MOCK_DATA=false
VITE_SENTRY_DSN=
